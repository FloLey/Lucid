# Required for Backend
GOOGLE_API_KEY=

# Optional: defaults to http://backend:8000 in Docker
VITE_API_TARGET=

# Set to 1 to enable JSONL debug logging of all LLM calls (backend/logs/llm_debug.jsonl)
LLM_DEBUG_LOG=

# Optional: comma-separated allowed CORS origins (default: localhost dev ports)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: rate limiter settings (default: 120 requests per 60 seconds per IP)
RATE_LIMIT_MAX_CALLS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Optional: log level for the backend (default: WARNING)
LOG_LEVEL=WARNING
